# =============================================================================
# FinRAG — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=local                          # local | staging | prod
APP_LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
APP_LOG_DIR=logs                       # Directory for JSONL log files
APP_REQUEST_TIMEOUT_SECONDS=60

# ── LLM Backend ────────────────────────────────────────────────────────────────
# Primary backend: "openai" | "local"
LLM_BACKEND=openai

# OpenAI (used as judge + optional answer model)
OPENAI_API_KEY=sk-...                  # Required if LLM_BACKEND=openai
OPENAI_MODEL=gpt-4o-mini              # Model for answer generation
OPENAI_JUDGE_MODEL=gpt-4o             # Model for offline evaluation / judge

# Local OSS model (llama.cpp / Ollama)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=mistral:7b-instruct

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2      # SentenceTransformers model name
EMBEDDING_BATCH_SIZE=64
EMBEDDING_CACHE_DIR=data/.embedding_cache

# ── Vector Store ───────────────────────────────────────────────────────────────
VECTOR_STORE_BACKEND=chroma            # chroma | weaviate (future)
CHROMA_PERSIST_DIR=data/index/chroma
CHROMA_COLLECTION_NAME=finrag_chunks

# ── Retrieval ──────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=6
RETRIEVAL_HYBRID_ALPHA=0.5             # 0.0=BM25 only, 1.0=vector only
RETRIEVAL_SCORE_THRESHOLD=0.3

# ── EDGAR / Data ───────────────────────────────────────────────────────────────
EDGAR_USER_AGENT=FinRAG research@example.com   # Required by SEC fair-use policy
EDGAR_RATE_LIMIT_CALLS=8               # Max requests per second (SEC limit: 10)
EDGAR_RATE_LIMIT_PERIOD=1
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed

# ── LlamaParse (Optional) ──────────────────────────────────────────────────────
LLAMAPARSE_API_KEY=                    # Leave empty to use local HTML parser
LLAMAPARSE_ENABLED=false

# ── Safety / Guardrails ────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
OPENAI_MODERATION_ENABLED=false        # Uses OpenAI moderation API if true

# ── API Server (Day 11) ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── LangSmith (Optional tracing) ───────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=finrag-local
