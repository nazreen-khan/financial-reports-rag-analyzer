# =============================================================================
# FinRAG — .gitignore
# =============================================================================

# ── Secrets ────────────────────────────────────────────────────────────────────
.env
*.pem
*.key

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
MANIFEST

# ── Virtual Environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Data (large files — versioned via DVC on Day 13) ──────────────────────────
data/raw/
data/processed/
data/index/
data/.embedding_cache/

# ── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log
*.jsonl

# ── IDE ────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing / Coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── DVC (Day 13) ───────────────────────────────────────────────────────────────
/tmp/
.dvc/tmp/

# ── Docker ─────────────────────────────────────────────────────────────────────
*.dockerenv
